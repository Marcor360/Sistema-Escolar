# ----- Servidor -----
PORT=3000
NOMBRE_INSTITUCION=Colegio Demo

# ----- Base de datos -----
# DB_TYPE: mysql | mssql  (cambiar motor sin tocar código)
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USER=escolar
DB_PASS=escolar123
DB_NAME=escolar
# El esquema se gestiona con database/*/migracion_*.sql; DB_SYNC solo para prototipos.
DB_SYNC=false

# SQL Server: DB_TYPE=mssql, DB_PORT=1433, DB_USER=sa, DB_PASS=Escolar123!

# ----- Auth -----
JWT_SECRET=cambiar-en-produccion
JWT_EXPIRES=8h
# Opcional para la app móvil de alumnos; más cómodo, mayor ventana de riesgo si se roba el token.
# JWT_EXPIRES_MOVIL=30d

# ----- Archivos -----
UPLOADS_DIR=./uploads
MAX_UPLOAD_MB=5

# ----- Correo (opcional; sin SMTP los correos se imprimen en consola) -----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Colegio Demo <no-reply@colegio.mx>"

# ----- Openpay (credenciales del cliente; ver contrato, cláusula DÉCIMA) -----
OPENPAY_MERCHANT_ID=
OPENPAY_PRIVATE_KEY=
OPENPAY_BASE_URL=https://sandbox-api.openpay.mx/v1
OPENPAY_REDIRECT_URL=http://localhost:5173/pago-completado

# ----- Seed -----
SEED_ADMIN_EMAIL=admin@escuela.mx
SEED_ADMIN_PASSWORD=Admin123!

# ----- Seguridad -----
# Producción: NODE_ENV=production desactiva Swagger y exige JWT_SECRET real
NODE_ENV=development
# Orígenes permitidos para CORS, separados por coma (vacío = abierto, solo desarrollo)
CORS_ORIGINS=
# Ejemplo producción:
# CORS_ORIGINS=https://portal.colegio.mx,https://app.colegio.mx
# Si configuras usuario/contraseña del webhook en el dashboard de Openpay, decláralos aquí
OPENPAY_WEBHOOK_USER=
OPENPAY_WEBHOOK_PASS=
